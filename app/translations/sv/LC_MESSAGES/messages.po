msgstr "okänt fel"

#: app/templates/settings_api.html:775
msgid "authentication failed"
msgstr "autentisering misslyckades"

#: app/templates/settings_api.html:776
msgid "timeout"
msgstr "timeout"

#: app/templates/settings_api.html:777
msgid "rate limit reached"
msgstr "kvot uppnådd"

#: app/templates/settings_api.html:778
