# Bookstation — miljövariabler
# Kopiera till .env och fyll i dina värden.

# --- Flask ---

# Hemlig nyckel för sessioner och CSRF-skydd.
# Generera ett säkert värde: python3 -c "import secrets; print(secrets.token_hex(32))"
BOOKSTATION_SECRET_KEY=byt-ut-mig-mot-ett-riktigt-hemligt-värde

# --- Loggning ---

# Loggningsnivå: DEBUG, INFO, WARNING, ERROR, CRITICAL
BOOKSTATION_LOG_LEVEL=INFO

# --- API-nycklar (valfria) ---

# Google Books API
BOOKSTATION_GOOGLE_BOOKS_KEY=

# Mistral AI — för AI-baserade metadataförslag (serie, ämnen m.m.)
# Hämta nyckel från https://console.mistral.ai/
BOOKSTATION_MISTRAL_API_KEY=
# Valfritt: modellnamn (standard: mistral-small-latest)
BOOKSTATION_MISTRAL_MODEL=

# --- Adobe Digital Editions (DRM-konvertering) ---

# Sökväg till ADE-binären, t.ex. /usr/bin/wine eller /opt/ade/DigitalEditions
# Lämna tomt om du inte använder ADE.
BOOKSTATION_ADE_CMD=
