# Colophon — miljövariabler
# Kopiera till .env och fyll i dina värden.

# --- Flask ---

# Hemlig nyckel för sessioner och CSRF-skydd.
# Generera ett säkert värde: python3 -c "import secrets; print(secrets.token_hex(32))"
COLOPHON_SECRET_KEY=byt-ut-mig-mot-ett-riktigt-hemligt-värde

# --- Sökvägar (i containern) ---
COLOPHON_LIBRARY_DIR=/books
COLOPHON_DATA_DIR=/data

# --- Sökvägar på värden (används av docker-compose) ---
COLOPHON_LIBRARY_HOST=./bibliotek
COLOPHON_DATA_HOST=./data

# --- Loggning ---

# Loggningsnivå: DEBUG, INFO, WARNING, ERROR, CRITICAL
COLOPHON_LOG_LEVEL=INFO

# --- API-nycklar (valfria) ---
# Alla nycklar nedan kan också konfigureras i UI under "API-inställningar".
# UI-värden (sparade i lokal databas) har prioritet — env används som fallback.

# Google Books API
COLOPHON_GOOGLE_BOOKS_KEY=

# AI-leverantör (provider-agnostisk, OpenAI-kompatibelt API)
# Standard: Mistral. Andra alternativ: OpenAI, DeepSeek, Ollama (lokal), m.fl.
COLOPHON_AI_API_URL=
COLOPHON_AI_API_KEY=
COLOPHON_AI_MODEL=

# Bakåtkompatibilitet: dessa läses fortfarande om COLOPHON_AI_* saknas.
# COLOPHON_MISTRAL_API_KEY=
# COLOPHON_MISTRAL_MODEL=

# Google Custom Search (omslagssökning via Googles bildsökning)
COLOPHON_GOOGLE_CSE_API_KEY=
COLOPHON_GOOGLE_CSE_ID=

# Bing Image Search (alternativ omslagskälla)
COLOPHON_BING_API_KEY=

# --- Upstream-bibliotek (valfritt, t.ex. Komga på NFS) ---

# Sökväg till upstream-biblioteket inuti containern
# COLOPHON_UPSTREAM_DIR=/upstream
# Sökväg på värden som monteras som /upstream
# COLOPHON_UPSTREAM_HOST=/mnt/synology_komga

# --- Adobe Digital Editions (DRM-konvertering) ---

# Sökväg till ADE-binären, t.ex. /usr/bin/wine eller /opt/ade/DigitalEditions
# Lämna tomt om du inte använder ADE.
COLOPHON_ADE_CMD=
